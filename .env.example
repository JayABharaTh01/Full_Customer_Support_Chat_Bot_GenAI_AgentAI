#####################################
# PINECONE
#####################################

PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_ENVIRONMENT=

#####################################
# DATABASE
#####################################

DATABASE_TYPE=sqlite
SQLITE_DB=./database/customer_support.db